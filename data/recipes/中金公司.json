{
  "company": "中金公司",
  "job_list_url": "https://cicc.zhiye.com/custom/social?&hideMenu=1",
  "job_list_schema": {
    "baseSelector": "tbody#joblist tr.tr_dom",
    "fields": [
      {
        "name": "title",
        "selector": "td:nth-child(2) b",
        "type": "text"
      },
      {
        "name": "location",
        "selector": "td:nth-child(5) span",
        "type": "text"
      },
      {
        "name": "link",
        "selector": "td:nth-child(2) a",
        "type": "attribute",
        "attribute": "href"
      },
      {
        "name": "job_id",
        "selector": "td:nth-child(2) b",
        "type": "text"
      }
    ]
  },
  "job_detail_url_template": null,
  "job_detail_schema": {
    "baseSelector": "div.wrap",
    "fields": [
      {
        "name": "job_desc",
        "selector": "div#Duty",
        "type": "text"
      },
      {
        "name": "job_requirements",
        "selector": "div#Require",
        "type": "text"
      }
    ]
  }
}